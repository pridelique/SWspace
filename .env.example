# Copy this file to .env for local development.
# Never commit .env to git.

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# CSRF (add your Vercel domain when in production)
# CSRF_TRUSTED_ORIGINS=https://your-app.vercel.app

# Committee verification code (keep secret in production)
COMMITTEE_VERIFICATION_CODE=COMMITTEE2024

# PostgreSQL via Supabase (leave blank to use SQLite locally)
# Use the Transaction Pooler connection string (port 6543) from Supabase dashboard
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Cloudinary (leave blank to store media locally)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret
